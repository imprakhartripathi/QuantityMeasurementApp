# -----------------------------
# Shared security settings
# -----------------------------
QMA_JWT_SECRET=change-me-to-a-long-random-secret-key-at-least-32-bytes
QMA_JWT_EXPIRATION_MS=3600000
QMA_COOKIE_SECURE=false

# -----------------------------
# OAuth / frontend settings
# For production:
#   QMA_FRONTEND_ORIGIN=https://app.your-subdomain.com
#   QMA_OAUTH2_REDIRECT_URI=https://app.your-subdomain.com/oauth/callback
# -----------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
QMA_FRONTEND_ORIGIN=http://localhost:8000
QMA_OAUTH2_REDIRECT_URI=http://localhost:8000/oauth/callback
QMA_GOOGLE_AUTH_REDIRECT_URI=http://localhost:4000/login/oauth2/code/google
QMA_CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# -----------------------------
# Local JVM mode (./start-microservices.sh local)
# -----------------------------
QMA_DB_URL=jdbc:postgresql://127.0.0.1:5432/quantity_measurement
QMA_DB_USERNAME=postgres
QMA_DB_PASSWORD=postgres

# -----------------------------
# Docker mode DB container settings
# -----------------------------
POSTGRES_DB=quantity_measurement
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
QMA_POSTGRES_HOST_PORT=5433

# -----------------------------
# Internal service URLs
# -----------------------------
QMA_AUTH_BASE_URL_LOCAL=http://localhost:5000
QMA_SERVICE_BASE_URL_LOCAL=http://localhost:6000
QMA_DOCKER_AUTH_BASE_URL=http://qma-auth:5000
QMA_DOCKER_SERVICE_BASE_URL=http://qma-service:6000

# -----------------------------
# Frontend API URL (used in client build and at container runtime)
# Leave empty to use same-origin `/api` proxy from qma-client nginx (recommended for Docker deploy).
# If frontend is hosted separately, set explicit API URL, e.g.
#   VITE_API_BASE_URL=https://api.your-subdomain.com
# -----------------------------
VITE_API_BASE_URL=

# -----------------------------
# Optional prebuilt image refs (for docker deploy mode)
# -----------------------------
QMA_API_IMAGE=ghcr.io/your-org/qma-api:latest
QMA_AUTH_IMAGE=ghcr.io/your-org/qma-auth:latest
QMA_SERVICE_IMAGE=ghcr.io/your-org/qma-service:latest
QMA_CLIENT_IMAGE=ghcr.io/your-org/qma-client:latest
