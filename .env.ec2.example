# ============================================================
# EC2 Deployment Environment (HTTP + direct port access)
# Copy this to `.env` on EC2 before running docker compose.
# ============================================================

# -----------------------------
# Shared security settings
# -----------------------------
QMA_JWT_SECRET=
QMA_JWT_EXPIRATION_MS=3600000

# If you are on plain HTTP (no TLS), keep false.
# Set true only when app/api are served over HTTPS.
QMA_COOKIE_SECURE=false

# -----------------------------
# Public URLs (EC2)
# Replace if your public host changes.
# -----------------------------
QMA_PUBLIC_HOST=44.214.101.102
QMA_FRONTEND_ORIGIN=https://qma.imprakhartripathi.in
QMA_OAUTH2_REDIRECT_URI=https://qma.imprakhartripathi.in/oauth/callback
QMA_GOOGLE_AUTH_REDIRECT_URI=http://44.214.101.102:4000/login/oauth2/code/google
QMA_CORS_ALLOWED_ORIGINS=https://qma.imprakhartripathi.in,http://44.214.101.102:8000,https://quantitymeasurement.netlify.app

# -----------------------------
# Google OAuth client
# -----------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------
# Database (dockerized postgres)
# -----------------------------
POSTGRES_DB=quantity_measurement
POSTGRES_USER=
POSTGRES_PASSWORD=
QMA_POSTGRES_HOST_PORT=5433

# Internal DB URL for local JVM mode (not used by docker mode, but required by local mode)
QMA_DB_URL=jdbc:postgresql://127.0.0.1:5432/quantity_measurement
QMA_DB_USERNAME=
QMA_DB_PASSWORD=

# -----------------------------
# Internal service URLs (for gateway)
# -----------------------------
QMA_AUTH_BASE_URL_LOCAL=http://localhost:5000
QMA_SERVICE_BASE_URL_LOCAL=http://localhost:6000
QMA_DOCKER_AUTH_BASE_URL=http://qma-auth:5000
QMA_DOCKER_SERVICE_BASE_URL=http://qma-service:6000

# -----------------------------
# Frontend API URL (used in client build and at container runtime)
# Leave empty to use same-origin `/api` proxy from qma-client nginx (recommended).
# Set explicitly only when frontend is hosted separately from qma-client.
# -----------------------------
VITE_API_BASE_URL=

# -----------------------------
# Optional prebuilt image refs (docker-deploy mode)
# -----------------------------
QMA_API_IMAGE=
QMA_AUTH_IMAGE=
QMA_SERVICE_IMAGE=
QMA_CLIENT_IMAGE=
